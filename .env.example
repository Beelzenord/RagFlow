# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis (n8n queue mode + future job queue) ───────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Generate locally: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-use-openssl-rand-hex-32
GENERIC_TIMEZONE=Europe/Stockholm
# Set to "queue" once you scale beyond a single n8n instance
EXECUTIONS_MODE=regular

# ─── LlamaParse / LlamaCloud ─────────────────────────────────────────────────
# Get a fresh key at https://cloud.llamaindex.ai (rotate any key shared in chat!)
LLAMA_CLOUD_API_KEY=

# ─── LLM + embedding provider ────────────────────────────────────────────────
# Provider: "openai" or "anthropic" (LLM only; embeddings always via OpenAI-compatible)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1

# ─── Ingestion service ───────────────────────────────────────────────────────
INGESTION_PORT=8001
STORAGE_DIR=/data/storage
MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/jpg,image/png
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ─── Query service ───────────────────────────────────────────────────────────
QUERY_PORT=8002
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.0

# ─── Internal service auth (n8n → FastAPI) ───────────────────────────────────
SERVICE_API_KEY=change-me-to-a-shared-secret

# ─── Web UI ──────────────────────────────────────────────────────────────────
WEB_PORT=8080
